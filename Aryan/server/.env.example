# Copy to server/.env — use Neon dashboard "pooled" connection string for server apps.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

PORT=3000
# Vite dev server for this app is on port 5174. Add production origins if needed.
CLIENT_ORIGIN=http://localhost:5174

# Required for auth (HS256). Use a long random string (32+ characters).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional: Pino log level (info, warn, error, debug, trace).
# LOG_LEVEL=info
