# Copy to server/.env — use Neon dashboard "pooled" connection string for server apps.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

PORT=3000
# Comma-separated browser origins for credentialed CORS. Include every Vite dev URL you use
# (client 5173, client-b 5174, client-c 5175) or login from that app will be blocked by the browser.
# Add your deployed frontend URL(s), e.g. ,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Vercel: add DATABASE_URL, CLIENT_ORIGIN (your deployed frontend URL), JWT_SECRET in
# Project → Settings → Environment Variables. Optional: UPLOAD_DIR=/tmp/ppd-uploads — the
# default data/uploads path is not writable on serverless; document uploads need /tmp or blob storage.

# Required for auth (HS256). Use a long random string (32+ characters).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional: Pino log level (info, warn, error, debug, trace).
# LOG_LEVEL=info
